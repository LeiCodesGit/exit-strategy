<%- include('../partials/header', { pageTitle: 'Dashboard', activePage: 'dashboard', extraCSS: '<link rel="stylesheet" href="/css/dashboard.css"/>' }) %>
<div class="page-header">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-sub">BS Computer Engineering · My Academic Tracker</p>
  </div>
</div>

<!-- STATS ROW -->
<div class="stats-grid">
  <div class="stat-card stat-primary">
    <div class="stat-value"><%= stats.progress || 0 %>%</div>
    <div class="stat-label">Overall Progress</div>
    <div class="progress-bar">
      <div class="progress-fill" id="prog-fill" data-width="<%= stats.progress || 0 %>"></div>
    </div>
  </div>
  <div class="stat-card stat-green">
    <div class="stat-value"><%= stats.compUnits %><span>/ <%= stats.total %></span></div>
    <div class="stat-label">Units Completed</div>
  </div>
  <div class="stat-card stat-green">
    <div class="stat-value"><%= stats.completed %></div>
    <div class="stat-label">Courses Completed</div>
  </div>
  <div class="stat-card stat-purple">
    <div class="stat-value"><%= stats.pending %></div>
    <div class="stat-label">Pending Grade</div>
  </div>
  <div class="stat-card stat-red">
    <div class="stat-value"><%= stats.retake %></div>
    <div class="stat-label">Retake & Remedial</div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= stats.toTake %></div>
    <div class="stat-label">To Take</div>
  </div>
</div>

<a href="/courses" class="view-tracker-link">View Full Course Tracker →</a>

<!-- CURRENT / ACTIVE COURSES -->
<% if (currentCourses.length || pendingCourses.length || retakeCourses.length || remedialCourses.length) { %>
<section class="section">
  <h2 class="section-title">Active This Term</h2>
  
  <p class="active-meta">
    <%= currentCourses.length + pendingCourses.length + retakeCourses.length + remedialCourses.length %> courses &nbsp;·&nbsp;
    <%= [...currentCourses, ...pendingCourses, ...retakeCourses, ...remedialCourses].reduce((s, c) => s + (c.units || 0), 0) %> units
  </p>

  <div class="course-table-wrap">
    <table class="course-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Course Name</th>
          <th>Units</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% currentCourses.forEach(c => { %>
        <tr id="row-<%= c._id %>">
          <td class="td-code"><%= c.code %></td>
          <td class="td-name"><%= c.name %></td>
          <td class="td-units"><%= c.units > 0 ? c.units : '—' %></td>
          <td><span class="status-badge status-taking" style="cursor:pointer" onclick="openModal('<%= c._id %>','<%= c.code %>','<%= c.status %>')">Taking</span></td>
          <td><button class="btn-sm" onclick="openEdit('<%= c._id %>','<%= c.code %>','<%= c.name %>',<%= c.units %>,'<%= c.yearLevel %>','<%= c.term %>','<%= c.status %>','<%= c.prerequisites %>')">Edit</button></td>
        </tr>
        <% }) %>
        <% pendingCourses.forEach(c => { %>
        <tr id="row-<%= c._id %>">
          <td class="td-code"><%= c.code %></td>
          <td class="td-name"><%= c.name %></td>
          <td class="td-units"><%= c.units > 0 ? c.units : '—' %></td>
          <td><span class="status-badge status-pending" style="cursor:pointer" onclick="openModal('<%= c._id %>','<%= c.code %>','<%= c.status %>')">Pending</span></td>
          <td><button class="btn-sm" onclick="openEdit('<%= c._id %>','<%= c.code %>','<%= c.name %>',<%= c.units %>,'<%= c.yearLevel %>','<%= c.term %>','<%= c.status %>','<%= c.prerequisites %>')">Edit</button></td>
        </tr>
        <% }) %>
        <% retakeCourses.forEach(c => { %>
        <tr id="row-<%= c._id %>">
          <td class="td-code"><%= c.code %></td>
          <td class="td-name"><%= c.name %></td>
          <td class="td-units"><%= c.units > 0 ? c.units : '—' %></td>
          <td><span class="status-badge status-retake" style="cursor:pointer" onclick="openModal('<%= c._id %>','<%= c.code %>','<%= c.status %>')">Retake</span></td>
          <td><button class="btn-sm" onclick="openEdit('<%= c._id %>','<%= c.code %>','<%= c.name %>',<%= c.units %>,'<%= c.yearLevel %>','<%= c.term %>','<%= c.status %>','<%= c.prerequisites %>')">Edit</button></td>
        </tr>
        <% }) %>
        <% remedialCourses.forEach(c => { %>
        <tr id="row-<%= c._id %>">
          <td class="td-code"><%= c.code %></td>
          <td class="td-name"><%= c.name %></td>
          <td class="td-units"><%= c.units > 0 ? c.units : '—' %></td>
          <td><span class="status-badge status-remedial" style="cursor:pointer" onclick="openModal('<%= c._id %>','<%= c.code %>','<%= c.status %>')">Remedial</span></td>
          <td><button class="btn-sm" onclick="openEdit('<%= c._id %>','<%= c.code %>','<%= c.name %>',<%= c.units %>,'<%= c.yearLevel %>','<%= c.term %>','<%= c.status %>','<%= c.prerequisites %>')">Edit</button></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<% } else { %>
<section class="section">
  <div class="empty-state">
    <div class="empty-icon">📚</div>
    <div class="empty-text">No active courses this term</div>
    <div class="empty-sub">Update your course statuses to track your progress</div>
  </div>
</section>
<% } %>

<%- include('../partials/modal') %>
<%- include('../partials/footer') %>