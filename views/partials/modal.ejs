<!-- STATUS MODAL -->
<div id="modal-overlay" class="modal-overlay" onclick="closeModal()">
  <div class="modal" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div>
        <div id="modal-code" class="modal-code"></div>
        <div class="modal-title">Update Status</div>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <label class="form-label">Status</label>
      <div class="status-options">
        <% ['Completed','Taking','Pending','Remedial','Retake','To Take'].forEach(s => { %>
        <label class="status-option status-opt-<%= s.toLowerCase().replace(' ','-') %>">
          <input type="radio" name="modal-status" value="<%= s %>"/>
          <span><%= s %></span>
        </label>
        <% }) %>
      </div>
      <label class="form-label" style="margin-top:1rem">Notes (optional)</label>
      <textarea id="modal-notes" class="form-textarea" placeholder="e.g. Remedial on March 30..."></textarea>
    </div>
    <div class="modal-footer">
      <button class="btn-ghost" onclick="closeModal()">Cancel</button>
      <button class="btn-primary" onclick="saveStatus()">Save</button>
    </div>
  </div>
</div>

<!-- EDIT MODAL -->
<div id="edit-overlay" class="modal-overlay" onclick="closeEdit()">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:520px">
    <div class="modal-header">
      <div>
        <div id="edit-code" class="modal-code"></div>
        <div class="modal-title">Edit Course</div>
      </div>
      <button class="modal-close" onclick="closeEdit()">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group" style="margin-bottom:0.75rem">
        <label class="form-label">Course Name</label>
        <input type="text" id="edit-name" class="form-input" placeholder="Course name"/>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem">
        <div class="form-group">
          <label class="form-label">Units</label>
          <input type="number" id="edit-units" class="form-input" min="0" max="10"/>
        </div>
        <div class="form-group">
          <label class="form-label">Year Level</label>
          <select id="edit-year" class="form-input">
            <% ['1st Year','2nd Year','3rd Year','4th Year'].forEach(y => { %>
              <option value="<%= y %>"><%= y %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem">
        <div class="form-group">
          <label class="form-label">Term</label>
          <select id="edit-term" class="form-input">
            <option value="1st">1st Term</option>
            <option value="2nd">2nd Term</option>
            <option value="3rd">3rd Term</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Status</label>
          <select id="edit-status" class="form-input">
            <% ['Completed','Taking','Pending','Remedial','Retake','To Take'].forEach(s => { %>
              <option value="<%= s %>"><%= s %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin-bottom:0.75rem">
        <label class="form-label">Prerequisites</label>
        <input type="text" id="edit-prereq" class="form-input" placeholder="e.g. MATH041, PHY035"/>
      </div>
      <div class="form-group">
        <label class="form-label">Notes</label>
        <textarea id="edit-notes" class="form-textarea" placeholder="e.g. Remedial on March 30..." style="min-height:60px"></textarea>
      </div>
    </div>
    <div class="modal-footer" style="justify-content:space-between">
      <button class="btn-delete" onclick="deleteCourse()">Delete</button>
      <div style="display:flex;gap:0.75rem">
        <button class="btn-ghost" onclick="closeEdit()">Cancel</button>
        <button class="btn-primary" style="width:auto" onclick="saveEdit()">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- WAIVER MODAL -->
<div id="waiver-overlay" class="modal-overlay" onclick="closeWaiver()">
  <div class="modal" onclick="event.stopPropagation()" style="max-width:480px">
    <div class="modal-header">
      <div>
        <div class="modal-code" style="color:var(--red)">⚠ Prerequisite Warning</div>
        <div class="modal-title">Some prerequisites are not yet completed</div>
      </div>
      <button class="modal-close" onclick="closeWaiver()">✕</button>
    </div>
    <div class="modal-body">
      <div id="waiver-missing" style="background:var(--red-bg);border:1px solid var(--red);border-radius:var(--radius);padding:0.75rem 1rem;margin-bottom:1rem;font-size:0.875rem;color:var(--red-text)"></div>
      <p style="color:var(--text2);font-size:0.875rem">Do you want to waive this requirement and proceed anyway?</p>
    </div>
    <div class="modal-footer" style="justify-content:space-between">
      <button class="btn-ghost" onclick="closeWaiver()">Cancel</button>
      <button class="btn-primary" style="width:auto;background:var(--red);border:none" onclick="confirmWaiver()">Yes, Apply Waiver</button>
    </div>
  </div>
</div>
