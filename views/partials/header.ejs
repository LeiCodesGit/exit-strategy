<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Exit Strategy | <%= typeof pageTitle !== 'undefined' ? pageTitle : 'My Academic Tracker' %></title>
  
  <link rel="icon" type="image/x-icon" href="/img/exit-strategy.ico">

  <link rel="manifest" href="/manifest.json"/>
  <link rel="apple-touch-icon" href="/img/exit-strategy-logo(2).png"/>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/base.css"/>
  <link rel="stylesheet" href="/css/modal.css"/>
  <%- typeof extraCSS !== 'undefined' ? extraCSS : '' %>
  </head>
<body>
<% if (user) { %>
<nav class="navbar">
  <a href="/dashboard" class="nav-brand">
    <img src="/img/exit-strategy-logo.png" alt="Exit Strategy Logo" style="height:28px;width:auto;vertical-align:middle;margin-right:8px;">
    Exit <span>Strategy</span>
  </a>
  <!-- Desktop nav links -->
  <div class="nav-links nav-links-desktop">
    <a href="/dashboard" class="<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
    <a href="/courses"  class="<%= typeof activePage !== 'undefined' && activePage === 'courses'   ? 'active' : '' %>">Courses</a>
    <a href="/roadmap"  class="<%= typeof activePage !== 'undefined' && activePage === 'roadmap'   ? 'active' : '' %>">Roadmap</a>
    <% if (user && user.isAdmin) { %>
    <a href="/admin"  class="<%= typeof activePage !== 'undefined' && activePage === 'admin' ? 'active' : '' %>" style="color:var(--accent-red, #e74c3c);">Admin</a>
    <% } %>
  </div>
  <div class="nav-user">
    <span><%= user.name.split(' ')[0] %></span>
    <form action="/logout" method="POST" style="display:inline">
      <button type="submit" class="btn-logout">Sign out</button>
    </form>
    <!-- Hamburger (mobile only) -->
    <button class="nav-hamburger" onclick="toggleMobileNav()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
<!-- Mobile nav drawer -->
<div class="mobile-nav" id="mobile-nav">
  <a href="/dashboard" class="<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">Dashboard</a>
  <a href="/courses"   class="<%= typeof activePage !== 'undefined' && activePage === 'courses'   ? 'active' : '' %>">Courses</a>
  <a href="/roadmap"   class="<%= typeof activePage !== 'undefined' && activePage === 'roadmap'   ? 'active' : '' %>">Roadmap</a>
  <% if (user && user.isAdmin) { %>
  <a href="/admin" class="<%= typeof activePage !== 'undefined' && activePage === 'admin' ? 'active' : '' %>" style="color:var(--accent-red,#e74c3c);">Admin</a>
  <% } %>
</div>
<script>
function toggleMobileNav() {
  document.getElementById('mobile-nav').classList.toggle('open');
}
// Close drawer when a link is tapped
document.querySelectorAll('.mobile-nav a').forEach(a =>
  a.addEventListener('click', () => document.getElementById('mobile-nav').classList.remove('open'))
);
</script>
<% } %>

<% if (success && success.length) { %>
  <div class="flash flash-success"><%= success[0] %></div>
<% } %>
<% if (error && error.length) { %>
  <div class="flash flash-error"><%= error[0] %></div>
<% } %>

<main class="<%= user ? 'with-nav' : '' %>">
